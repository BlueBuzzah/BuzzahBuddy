    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="BackgroundColor" Value="{StaticResource PageBackground}" />
    </Style>

    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="Shell.BackgroundColor" Value="{StaticResource PageBackground}" />
        <Setter Property="Shell.ForegroundColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="Shell.TitleColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="Shell.DisabledColor" Value="{StaticResource PageBackground}" />
        <Setter Property="Shell.UnselectedColor" Value="{StaticResource TextMuted}" />
        <Setter Property="Shell.NavBarHasShadow" Value="False" />
        <Setter Property="Shell.TabBarBackgroundColor" Value="{StaticResource CardBackground}" />
        <Setter Property="Shell.TabBarForegroundColor" Value="{StaticResource Primary}" />
        <Setter Property="Shell.TabBarTitleColor" Value="{StaticResource Primary}" />
        <Setter Property="Shell.TabBarUnselectedColor" Value="{StaticResource TextMuted}" />
    </Style>

    <Style TargetType="NavigationPage">
        <Setter Property="BarBackgroundColor" Value="{StaticResource PageBackground}" />
        <Setter Property="BarTextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="IconColor" Value="{StaticResource TextPrimary}" />
    </Style>

    <Style TargetType="TabbedPage">
        <Setter Property="BarBackgroundColor" Value="{StaticResource CardBackground}" />
        <Setter Property="BarTextColor" Value="{StaticResource Primary}" />
        <Setter Property="UnselectedTabColor" Value="{StaticResource PageBackground}" />
        <Setter Property="SelectedTabColor" Value="{StaticResource Primary}" />
    </Style>

    <!-- BlueBuzzah.com Glow Styles -->
    <Style x:Key="PrimaryButtonGlow" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="{StaticResource GlowBrush}"
                        Offset="0,0"
                        Radius="20"
                        Opacity="0.3" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SecondaryButtonGlow" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="{StaticResource GlowBrush}"
                        Offset="0,0"
                        Radius="20"
                        Opacity="0.3" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CardWithGlow" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource CardBackground}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Stroke" Value="{StaticResource CardBorder}" />
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="{StaticResource GlowBrush}"
                        Offset="0,0"
                        Radius="15"
                        Opacity="0.2" />
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
