<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Note: For Android please see also Platforms\Android\Resources\values\colors.xml -->
    <!-- Dark Mode Only - BlueBuzzah.com Design System -->

    <!-- Primary Blue Theme Colors (BlueBuzzah.com Palette) -->
    <Color x:Key="Primary">#35B6F2</Color>
    <Color x:Key="PrimaryLight">#5fc8f7</Color>
    <Color x:Key="PrimaryDark">#35B6F2</Color>
    <Color x:Key="PrimaryHover">#2da8e0</Color>
    <Color x:Key="PrimaryDarkText">#0a0a0a</Color>
    <Color x:Key="Secondary">#05212D</Color>
    <Color x:Key="SecondaryLight">#0d3a4d</Color>
    <Color x:Key="SecondaryDarkText">#fafafa</Color>
    <Color x:Key="Tertiary">#35B6F2</Color>

    <!-- Base Colors -->
    <Color x:Key="White">#fafafa</Color>
    <Color x:Key="Black">#0a0a0a</Color>
    <Color x:Key="MidnightBlue">#05212D</Color>
    <Color x:Key="OffBlack">#0a0a0a</Color>

    <!-- Semantic Dark Mode Colors -->
    <Color x:Key="PageBackground">#0a0a0a</Color>
    <Color x:Key="CardBackground">#05212D</Color>
    <Color x:Key="CardBackgroundLight">#0d3a4d</Color>
    <Color x:Key="CardBorder">#0A3143</Color>
    <Color x:Key="TextPrimary">#fafafa</Color>
    <Color x:Key="TextMuted">#a3a3a3</Color>
    <Color x:Key="GlowColor">#35B6F2</Color>
    <Color x:Key="OverlayBackground">#80000000</Color>

    <!-- Blue-Tinted Status Colors (WCAG AA Compliant) -->
    <Color x:Key="Success">#35B6F2</Color>
    <Color x:Key="Warning">#f59e0b</Color>
    <Color x:Key="Danger">#e11d48</Color>
    <Color x:Key="DangerDark">#fb7185</Color>

    <!-- Translucent Chip Backgrounds -->
    <Color x:Key="PrimaryChipBackground">#1A35B6F2</Color>
    <Color x:Key="WarningChipBackground">#1AF59E0B</Color>
    <Color x:Key="DangerChipBackground">#1AE11D48</Color>

    <!-- Saturated Button Colors (WCAG AA Compliant) -->
    <Color x:Key="DangerButton">#dc2626</Color>
    <Color x:Key="DangerButtonText">#fafafa</Color>
    <Color x:Key="WarningButton">#f59e0b</Color>
    <Color x:Key="WarningButtonText">#0a0a0a</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>

    <!-- Semantic Dark Mode Brushes -->
    <SolidColorBrush x:Key="PageBackgroundBrush" Color="{StaticResource PageBackground}"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackground}"/>
    <SolidColorBrush x:Key="CardBorderBrush" Color="{StaticResource CardBorder}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}"/>
    <SolidColorBrush x:Key="GlowBrush" Color="{StaticResource GlowColor}"/>

    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource Success}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource Warning}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource Danger}"/>
</ResourceDictionary>