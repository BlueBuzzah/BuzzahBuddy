<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:BuzzahBuddy"
             xmlns:converters="clr-namespace:BuzzahBuddy.Converters"
             x:Class="BuzzahBuddy.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Value Converters -->
            <converters:InvertedBoolConverter x:Key="InvertedBoolConverter" />
            <converters:IsNotNullConverter x:Key="IsNotNullConverter" />
            <converters:ContinuousModeConverter x:Key="ContinuousModeConverter" />
            <converters:IntToColorConverter x:Key="IntToColorConverter" />
            <converters:IntToTextColorConverter x:Key="IntToTextColorConverter" />
            <converters:AllTrueConverter x:Key="AllTrueConverter" />
            <converters:EnumToBoolConverter x:Key="EnumToBoolConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
