<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BuzzahBuddy.ViewModels"
             xmlns:models="clr-namespace:BuzzahBuddy.Models"
             xmlns:controls="clr-namespace:BuzzahBuddy.Views.Controls"
             x:Class="BuzzahBuddy.Views.DeviceListPage"
             x:DataType="vm:DeviceListViewModel"
             x:Name="page"
             Title="{Binding Title}">

    <Grid RowDefinitions="*,Auto" Padding="20">

        <!-- Connected Device View - Show when connected -->
        <ScrollView Grid.Row="0"
                    IsVisible="{Binding ConnectionInfo.IsConnected}">
            <VerticalStackLayout Spacing="20">

                <!-- Connection Status Banner -->
                <VerticalStackLayout Spacing="15">
                    <Label Text="Connected Device"
                           Style="{StaticResource Headline}"
                           HorizontalTextAlignment="Center"
                           SemanticProperties.HeadingLevel="Level1" />

                    <controls:ConnectionStatusBanner
                        ConnectionState="{Binding ConnectionInfo.ConnectionState}"
                        DeviceName="{Binding ConnectionInfo.ConnectedDeviceName}" />
                </VerticalStackLayout>

                <!-- Session-active hint: device settings are locked during a session -->
                <Label Text="End the therapy session to change device settings."
                       IsVisible="{Binding Settings.IsSessionActive}"
                       TextColor="{StaticResource Warning}"
                       FontSize="14"
                       HorizontalTextAlignment="Center"
                       SemanticProperties.Description="Device settings are locked while a therapy session is active"
                       AutomationId="SessionActiveHint" />

                <!-- Therapy Profile Selection -->
                <VerticalStackLayout Spacing="12">
                    <Label Text="Therapy Profile"
                           Style="{StaticResource Heading2}"
                           SemanticProperties.HeadingLevel="Level2" />

                    <Label Text="{Binding Settings.ProfileStatusMessage}"
                           IsVisible="{Binding Settings.ProfileStatusMessage, Converter={StaticResource IsNotNullConverter}}"
                           TextColor="{StaticResource Warning}"
                           FontSize="12"
                           SemanticProperties.Description="{Binding Settings.ProfileStatusMessage}"
                           AutomationId="ProfileStatusLabel" />

                    <!-- Profile Cards: tap = select and apply to the gloves -->
                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding Settings.AvailableProfiles}"
                                         Spacing="16">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="vm:ProfileItemViewModel">
                                <Border Padding="20"
                                        BackgroundColor="{StaticResource CardBackground}"
                                        StrokeThickness="2"
                                        Stroke="{StaticResource CardBorder}"
                                        SemanticProperties.Description="{Binding DisplayName}"
                                        SemanticProperties.Hint="Tap to select this therapy profile, then press Apply Settings to send it to the gloves">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12" />
                                    </Border.StrokeShape>

                                    <!-- Tap to select this profile. x:DataType cleared + x:Reference on purpose:
                                         RelativeSource AncestorType bindings silently fail to resolve in item
                                         templates on device (see Connect button). -->
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer x:DataType="{x:Null}"
                                                              Command="{Binding Source={x:Reference page}, Path=BindingContext.Settings.SelectProfileCommand}"
                                                              CommandParameter="{Binding}"
                                                              Tapped="OnProfileCardTapped" />
                                    </Border.GestureRecognizers>

                                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" ColumnSpacing="16" RowSpacing="8">
                                        <!-- Blue circle checkmark - SIMPLE binding to IsSelected -->
                                        <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
                                                WidthRequest="56"
                                                HeightRequest="56"
                                                BackgroundColor="{StaticResource Primary}"
                                                VerticalOptions="Center"
                                                HorizontalOptions="Center"
                                                IsVisible="{Binding IsSelected}"
                                                InputTransparent="True"
                                                AutomationProperties.IsInAccessibleTree="False">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="28" />
                                            </Border.StrokeShape>

                                            <Label Text="✓"
                                                   FontSize="32"
                                                   FontAttributes="Bold"
                                                   TextColor="{StaticResource PrimaryDarkText}"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center" />
                                        </Border>

                                        <!-- Profile Name -->
                                        <Label Grid.Row="0" Grid.Column="1"
                                               Text="{Binding Name}"
                                               FontSize="20"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource TextPrimary}"
                                               AutomationProperties.IsInAccessibleTree="False" />

                                        <!-- Profile Description -->
                                        <Label Grid.Row="1" Grid.Column="1"
                                               Text="{Binding Description}"
                                               FontSize="15"
                                               TextColor="{StaticResource TextMuted}"
                                               LineBreakMode="WordWrap"
                                               AutomationProperties.IsInAccessibleTree="False" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>

                </VerticalStackLayout>

                <!-- Device Options -->
                <VerticalStackLayout Spacing="12">
                    <Label Text="Device Options"
                           Style="{StaticResource Heading2}"
                           SemanticProperties.HeadingLevel="Level2" />

                    <Border Padding="15"
                            BackgroundColor="{StaticResource CardBackground}"
                            StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>

                        <VerticalStackLayout Spacing="10">
                            <!-- Device setting: therapy LED off (THERAPY_LED_OFF). Hidden until read from device. -->
                            <Grid ColumnDefinitions="*,Auto"
                                  MinimumHeightRequest="48"
                                  IsVisible="{Binding Settings.TherapyLedLoaded}">
                                <Label Grid.Column="0"
                                       Text="Turn LED Off During Therapy"
                                       FontSize="16"
                                       VerticalOptions="Center"
                                       LineBreakMode="WordWrap" />
                                <Switch Grid.Column="1"
                                        IsToggled="{Binding Settings.TherapyLedOff}"
                                        IsEnabled="{Binding Settings.TherapyLedBusy, Converter={StaticResource InvertedBoolConverter}}"
                                        VerticalOptions="Center"
                                        SemanticProperties.Description="Turn the glove's status light off during therapy sessions to avoid visual distraction"
                                        SemanticProperties.Hint="Double tap to toggle the therapy LED setting"
                                        AutomationId="TherapyLedOffSwitch" />
                            </Grid>

                            <Button Text="Test Connection"
                                    Command="{Binding Settings.TestConnectionCommand}"
                                    Style="{StaticResource TertiaryButton}"
                                    SemanticProperties.Hint="Send a brief test pulse to the device"
                                    SemanticProperties.Description="Test connection with brief vibration pulse"
                                    AutomationId="TestConnectionButton">
                                <Button.IsEnabled>
                                    <MultiBinding Converter="{StaticResource AllTrueConverter}">
                                        <Binding Path="Settings.IsNotTestingConnection" />
                                        <Binding Path="ConnectionInfo.IsConnected" />
                                    </MultiBinding>
                                </Button.IsEnabled>
                            </Button>

                            <Button Text="Calibrate Motors"
                                    Command="{Binding Settings.NavigateToCalibrationCommand}"
                                    Style="{StaticResource TertiaryButton}"
                                    SemanticProperties.Description="Open motor calibration for testing individual finger motors"
                                    SemanticProperties.Hint="Double tap to navigate to calibration"
                                    AutomationId="CalibrateMotorsButton">
                                <Button.IsEnabled>
                                    <MultiBinding Converter="{StaticResource AllTrueConverter}">
                                        <Binding Path="ConnectionInfo.IsConnected" />
                                        <Binding Path="Settings.IsSessionInactive" />
                                    </MultiBinding>
                                </Button.IsEnabled>
                            </Button>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <!-- Battery Status -->
                <VerticalStackLayout Spacing="12">
                    <Label Text="Battery Status"
                           Style="{StaticResource Heading2}"
                           SemanticProperties.HeadingLevel="Level2" />

                    <Border Padding="15"
                            BackgroundColor="{StaticResource CardBackground}"
                            StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>

                        <VerticalStackLayout Spacing="12">
                            <!-- One row per glove: dot | name | value, columns aligned -->
                            <Grid ColumnDefinitions="Auto,Auto,*"
                                  RowDefinitions="Auto,Auto"
                                  ColumnSpacing="8"
                                  RowSpacing="10">
                                <!-- Primary Glove -->
                                <Label Grid.Row="0" Grid.Column="0"
                                       Text="●"
                                       FontSize="16"
                                       TextColor="{Binding Settings.BatteryPrimaryColor}"
                                       VerticalOptions="Center"
                                       AutomationProperties.IsInAccessibleTree="False" />
                                <Label Grid.Row="0" Grid.Column="1"
                                       Text="Primary:"
                                       FontSize="14"
                                       VerticalOptions="Center"
                                       AutomationProperties.IsInAccessibleTree="False" />
                                <Label Grid.Row="0" Grid.Column="2"
                                       Text="{Binding Settings.BatteryPrimaryText}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       HorizontalOptions="End"
                                       VerticalOptions="Center"
                                       SemanticProperties.Description="{Binding Settings.BatteryPrimaryDescription}" />

                                <!-- Secondary Glove -->
                                <Label Grid.Row="1" Grid.Column="0"
                                       Text="●"
                                       FontSize="16"
                                       TextColor="{Binding Settings.BatterySecondaryColor}"
                                       VerticalOptions="Center"
                                       AutomationProperties.IsInAccessibleTree="False" />
                                <Label Grid.Row="1" Grid.Column="1"
                                       Text="Secondary:"
                                       FontSize="14"
                                       VerticalOptions="Center"
                                       AutomationProperties.IsInAccessibleTree="False" />
                                <Label Grid.Row="1" Grid.Column="2"
                                       Text="{Binding Settings.BatterySecondaryText}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       HorizontalOptions="End"
                                       VerticalOptions="Center"
                                       SemanticProperties.Description="{Binding Settings.BatterySecondaryDescription}" />
                            </Grid>

                            <Label Text="{Binding Settings.BatteryStatusMessage}"
                                   IsVisible="{Binding Settings.BatteryStatusMessage, Converter={StaticResource IsNotNullConverter}}"
                                   TextColor="{StaticResource Warning}"
                                   FontSize="12"
                                   HorizontalTextAlignment="Center"
                                   SemanticProperties.Description="Battery status warning" />

                            <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                                <ActivityIndicator IsRunning="{Binding Settings.IsRefreshingBattery}"
                                                   IsVisible="{Binding Settings.IsRefreshingBattery}"
                                                   HeightRequest="20"
                                                   WidthRequest="20"
                                                   SemanticProperties.Description="Refreshing battery status" />
                                <Button Text="🔄 Refresh"
                                        Command="{Binding Settings.RefreshBatteryCommand}"
                                        Style="{StaticResource TertiaryButton}"
                                        HorizontalOptions="Center"
                                        Padding="20,0"
                                        SemanticProperties.Hint="Refresh battery levels"
                                        SemanticProperties.Description="Updates the current battery status"
                                        AutomationId="RefreshBatteryButton">
                                    <Button.IsEnabled>
                                        <MultiBinding Converter="{StaticResource AllTrueConverter}">
                                            <Binding Path="Settings.IsNotRefreshingBattery" />
                                            <Binding Path="ConnectionInfo.IsConnected" />
                                        </MultiBinding>
                                    </Button.IsEnabled>
                                </Button>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <!-- Apply Settings: writes all pending device settings to the gloves -->
                <Button Text="Apply Settings"
                        Command="{Binding Settings.ApplySettingsCommand}"
                        Style="{StaticResource PrimaryButtonGlow}"
                        Margin="0,8,0,0"
                        SemanticProperties.Description="Applies the selected therapy profile and device options to the gloves"
                        SemanticProperties.Hint="Double tap to apply all pending device settings"
                        AutomationId="ApplyDeviceSettingsButton">
                    <Button.IsEnabled>
                        <MultiBinding Converter="{StaticResource AllTrueConverter}">
                            <Binding Path="ConnectionInfo.IsConnected" />
                            <Binding Path="Settings.IsSessionInactive" />
                            <Binding Path="Settings.HasPendingChanges" />
                            <Binding Path="Settings.IsNotBusy" />
                        </MultiBinding>
                    </Button.IsEnabled>
                </Button>

                <!-- Disconnect -->
                <Button Text="Disconnect Device"
                        Command="{Binding DisconnectCommand}"
                        Style="{StaticResource DangerActionButton}"
                        Margin="0,8,0,0"
                        SemanticProperties.Hint="Disconnect from current device"
                        SemanticProperties.Description="Tap to disconnect from the connected device"
                        AutomationId="DisconnectButton" />

            </VerticalStackLayout>
        </ScrollView>

        <!-- Device Scanning View - Show when NOT connected -->
        <Grid Grid.Row="0"
              RowDefinitions="Auto,*,Auto,Auto"
              IsVisible="{Binding ConnectionInfo.IsConnected, Converter={StaticResource InvertedBoolConverter}}">

            <!-- TOP ZONE: Header Info (Read-Only) -->
            <VerticalStackLayout Grid.Row="0" Spacing="10" Margin="0,0,0,16">
                <Label Text="Available Devices"
                       Style="{StaticResource Headline}"
                       SemanticProperties.HeadingLevel="Level1" />

                <Label Text="Bluetooth is disabled. Please enable Bluetooth to scan for devices."
                       FontSize="16"
                       TextColor="{StaticResource DangerDark}"
                       IsVisible="{Binding BluetoothEnabled, Converter={StaticResource InvertedBoolConverter}}"
                       LineBreakMode="WordWrap" />
            </VerticalStackLayout>

            <!-- Device List with pull-to-refresh; EmptyView carries the ready/scanning/no-results states -->
            <RefreshView Grid.Row="1"
                         IsRefreshing="{Binding IsRefreshing}"
                         Command="{Binding RefreshDevicesCommand}"
                         RefreshColor="{StaticResource Primary}">
                <CollectionView ItemsSource="{Binding AvailableDevices}"
                                SelectionMode="None"
                                ItemSizingStrategy="MeasureFirstItem">
                    <CollectionView.EmptyView>
                        <Grid>
                            <!-- State 1: Ready to Scan (before first scan) -->
                            <VerticalStackLayout Spacing="16"
                                                 Padding="20"
                                                 VerticalOptions="Center"
                                                 IsVisible="{Binding ShowReadyState}">
                                <Label Text="📱"
                                       FontSize="64"
                                       HorizontalOptions="Center"
                                       AutomationProperties.IsInAccessibleTree="False" />
                                <Label Text="Ready to Connect"
                                       Style="{StaticResource Heading2}"
                                       HorizontalTextAlignment="Center"
                                       SemanticProperties.HeadingLevel="Level2" />
                                <Label Text="Power on your BlueBuzzah gloves and tap 'Scan for Devices' below to begin searching."
                                       Style="{StaticResource BodyText}"
                                       HorizontalTextAlignment="Center"
                                       LineBreakMode="WordWrap" />
                            </VerticalStackLayout>

                            <!-- State 2: Scanning -->
                            <VerticalStackLayout Spacing="20"
                                                 Padding="20"
                                                 VerticalOptions="Center"
                                                 IsVisible="{Binding IsScanning}">
                                <ActivityIndicator IsRunning="{Binding IsScanning}"
                                                   HeightRequest="64"
                                                   WidthRequest="64"
                                                   Color="{StaticResource Primary}"
                                                   HorizontalOptions="Center"
                                                   SemanticProperties.Description="Scanning for nearby Bluetooth devices" />
                                <Label Text="Scanning for Devices..."
                                       Style="{StaticResource Heading2}"
                                       HorizontalTextAlignment="Center"
                                       SemanticProperties.HeadingLevel="Level2" />
                                <Label Text="Looking for nearby BlueBuzzah gloves. This may take a few moments."
                                       Style="{StaticResource BodyText}"
                                       HorizontalTextAlignment="Center"
                                       LineBreakMode="WordWrap"
                                       TextColor="{StaticResource TextMuted}" />
                            </VerticalStackLayout>

                            <!-- State 3: No Devices Found (scan completed empty) -->
                            <VerticalStackLayout Spacing="16"
                                                 Padding="20"
                                                 VerticalOptions="Center"
                                                 IsVisible="{Binding ShowNoResultsState}">
                                <Label Text="🔍"
                                       FontSize="64"
                                       HorizontalOptions="Center"
                                       AutomationProperties.IsInAccessibleTree="False" />
                                <Label Text="No Devices Found"
                                       Style="{StaticResource Heading2}"
                                       HorizontalTextAlignment="Center"
                                       SemanticProperties.HeadingLevel="Level2" />
                                <Label Text="No BlueBuzzah gloves were detected. Please check the following and try scanning again."
                                       Style="{StaticResource BodyText}"
                                       HorizontalTextAlignment="Center"
                                       LineBreakMode="WordWrap" />
                                <Border Padding="12"
                                        BackgroundColor="{StaticResource CardBackground}"
                                        StrokeThickness="0"
                                        Margin="0,8,0,0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="8" />
                                    </Border.StrokeShape>
                                    <VerticalStackLayout Spacing="8">
                                        <Label Text="Troubleshooting:"
                                               FontSize="14"
                                               FontAttributes="Bold" />
                                        <Label Text="• Ensure Bluetooth is enabled on your device"
                                               Style="{StaticResource SecondaryText}" />
                                        <Label Text="• Check that gloves are charged and powered on"
                                               Style="{StaticResource SecondaryText}" />
                                        <Label Text="• Move closer to the gloves (within 30 feet)"
                                               Style="{StaticResource SecondaryText}" />
                                    </VerticalStackLayout>
                                </Border>
                                <Label Text="{Binding ScanStatusMessage}"
                                       IsVisible="{Binding ScanStatusMessage, Converter={StaticResource IsNotNullConverter}}"
                                       TextColor="{StaticResource TextMuted}"
                                       FontSize="14"
                                       HorizontalTextAlignment="Center"
                                       AutomationId="ScanStatusLabel" />
                            </VerticalStackLayout>
                        </Grid>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:GloveDevice">
                            <Border Padding="15"
                                    Margin="0,0,0,10"
                                    BackgroundColor="{StaticResource CardBackground}"
                                    StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12" />
                                </Border.StrokeShape>

                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                    <Label Grid.Row="0" Grid.Column="0"
                                           Text="{Binding Name}"
                                           FontSize="18"
                                           FontAttributes="Bold" />

                                    <Label Grid.Row="1" Grid.Column="0"
                                           Text="{Binding SignalStrengthDisplay}"
                                           FontSize="14"
                                           TextColor="{StaticResource TextMuted}" />

                                    <!-- Connect Button: x:DataType must be cleared and x:Reference used here.
                                         RelativeSource AncestorType compiles (no XC0023) but silently fails to
                                         resolve inside CollectionView's recycled item containers on device,
                                         leaving the button dead. Do not convert back to silence the warning. -->
                                    <Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                                            x:DataType="{x:Null}"
                                            Text="Connect"
                                            Command="{Binding Source={x:Reference page}, Path=BindingContext.ConnectCommand}"
                                            CommandParameter="{Binding}"
                                            HeightRequest="48"
                                            CornerRadius="8"
                                            VerticalOptions="Center"
                                            IsEnabled="{Binding Source={x:Reference page}, Path=BindingContext.IsConnecting, Converter={StaticResource InvertedBoolConverter}}"
                                            SemanticProperties.Description="Connect to this Bluetooth device"
                                            SemanticProperties.Hint="Double tap to connect"
                                            AutomationId="ConnectDeviceButton" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </RefreshView>

            <!-- Still-scanning strip: EmptyView hides once a device is listed, but the scan
                 keeps running — keep telling the user more devices may still appear -->
            <HorizontalStackLayout Grid.Row="2"
                                   Spacing="8"
                                   HorizontalOptions="Center"
                                   Margin="0,8,0,0"
                                   IsVisible="{Binding ShowScanningWithResults}">
                <ActivityIndicator IsRunning="{Binding ShowScanningWithResults}"
                                   HeightRequest="20"
                                   WidthRequest="20"
                                   Color="{StaticResource Primary}" />
                <Label Text="Still scanning for more devices..."
                       Style="{StaticResource SecondaryText}"
                       VerticalOptions="Center"
                       AutomationId="StillScanningLabel" />
            </HorizontalStackLayout>

            <!-- BOTTOM ZONE (Easy Reach): Primary Action with Glow -->
            <Button Grid.Row="3"
                    Text="{Binding ScanButtonText}"
                    Command="{Binding ToggleScanCommand}"
                    Style="{StaticResource SecondaryButtonGlow}"
                    Margin="0,12,0,0"
                    SemanticProperties.Hint="Double tap to activate"
                    SemanticProperties.Description="{Binding ScanButtonDescription}"
                    AutomationId="ScanToggleButton" />
        </Grid>

        <!-- Connection Progress Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                BackgroundColor="{StaticResource OverlayBackground}"
                IsVisible="{Binding IsConnecting}"
                InputTransparent="False">
            <VerticalStackLayout Spacing="15"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"
                                SemanticProperties.Description="Connecting to device, please wait">
                <ActivityIndicator IsRunning="{Binding IsConnecting}"
                                 Color="{StaticResource White}"
                                 HeightRequest="50"
                                 WidthRequest="50"
                                 SemanticProperties.Description="Connection in progress" />
                <Label Text="Connecting to device..."
                       TextColor="{StaticResource TextPrimary}"
                       FontSize="18"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center"
                       AutomationProperties.IsInAccessibleTree="False" />
            </VerticalStackLayout>
        </Border>

    </Grid>

</ContentPage>
