<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BuzzahBuddy.ViewModels"
             x:Class="BuzzahBuddy.Views.CalibrationPage"
             x:DataType="vm:CalibrationViewModel"
             Title="{Binding Title}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="25">

            <!-- Header -->
            <Label Text="Motor Calibration"
                   Style="{StaticResource Headline}"
                   SemanticProperties.HeadingLevel="Level1"
                   HorizontalOptions="Center" />

            <!-- Calibration Mode Controls -->
            <Border Padding="15"
                    BackgroundColor="{StaticResource CardBackground}"
                    StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="15">
                    <Label Text="Calibration Mode"
                           Style="{StaticResource Heading2}"
                           SemanticProperties.HeadingLevel="Level2" />

                    <Label Text="Test individual finger motors to verify proper operation and adjust intensity."
                           Style="{StaticResource SecondaryText}"
                           LineBreakMode="WordWrap" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button Grid.Column="0"
                                Text="Enter Calibration"
                                Command="{Binding EnterCalibrationModeCommand}"
                                IsEnabled="{Binding IsInCalibrationMode, Converter={StaticResource InvertedBoolConverter}}"
                                Style="{StaticResource SecondaryButton}"
                                BackgroundColor="{StaticResource Primary}"
                                SemanticProperties.Description="Enter calibration mode to test and adjust finger motors"
                                SemanticProperties.Hint="Double tap to enter calibration mode"
                                AutomationId="EnterCalibrationButton" />

                        <Button Grid.Column="1"
                                Text="Exit Calibration"
                                Command="{Binding ExitCalibrationModeCommand}"
                                IsEnabled="{Binding IsInCalibrationMode}"
                                Style="{StaticResource SecondaryButton}"
                                BackgroundColor="{StaticResource Secondary}"
                                SemanticProperties.Description="Exit calibration mode and return to normal operation"
                                SemanticProperties.Hint="Double tap to exit calibration mode"
                                AutomationId="ExitCalibrationButton" />
                    </Grid>

                    <Label Text="{Binding IsInCalibrationMode, StringFormat='Status: {0}'}"
                           FontSize="14"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           TextColor="{StaticResource Primary}"
                           SemanticProperties.Description="{Binding IsInCalibrationMode, StringFormat='Calibration mode is {0}'}"
                           AutomationId="CalibrationStatusLabel" />
                </VerticalStackLayout>
            </Border>

            <!-- Guided Wizard (Only visible when in calibration mode) -->
            <Border Padding="20"
                    BackgroundColor="{StaticResource CardBackground}"
                    StrokeThickness="0"
                    IsVisible="{Binding IsInCalibrationMode}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="20">
                    <!-- Step Title & Description -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="{Binding StepTitle}"
                               Style="{StaticResource Heading2}"
                               HorizontalOptions="Center"
                               SemanticProperties.HeadingLevel="Level2" />

                        <Label Text="{Binding StepDescription}"
                               Style="{StaticResource BodyText}"
                               HorizontalTextAlignment="Center"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>

                    <!-- Step 1: Intensity Selection (Stepped Buttons) -->
                    <VerticalStackLayout Spacing="12" IsVisible="{Binding CurrentStep, Converter={StaticResource EqualConverter}, ConverterParameter=1}">
                        <Label Text="Select Intensity Level"
                               Style="{StaticResource Heading3}"
                               HorizontalOptions="Center"
                               SemanticProperties.HeadingLevel="Level3" />

                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="10">
                            <!-- 20% Intensity -->
                            <Button Grid.Row="0" Grid.Column="0"
                                    Text="20%"
                                    Command="{Binding SetIntensityCommand}"
                                    CommandParameter="20"
                                    Style="{StaticResource TertiaryButton}"
                                    BackgroundColor="{Binding Intensity, Converter={StaticResource IntToColorConverter}, ConverterParameter=20}"
                                    SemanticProperties.Description="Set intensity to 20 percent, gentle"
                                    AutomationId="Intensity20Button" />

                            <!-- 40% Intensity -->
                            <Button Grid.Row="0" Grid.Column="1"
                                    Text="40%"
                                    Command="{Binding SetIntensityCommand}"
                                    CommandParameter="40"
                                    Style="{StaticResource TertiaryButton}"
                                    BackgroundColor="{Binding Intensity, Converter={StaticResource IntToColorConverter}, ConverterParameter=40}"
                                    SemanticProperties.Description="Set intensity to 40 percent, light"
                                    AutomationId="Intensity40Button" />

                            <!-- 60% Intensity -->
                            <Button Grid.Row="1" Grid.Column="0"
                                    Text="60%"
                                    Command="{Binding SetIntensityCommand}"
                                    CommandParameter="60"
                                    Style="{StaticResource TertiaryButton}"
                                    BackgroundColor="{Binding Intensity, Converter={StaticResource IntToColorConverter}, ConverterParameter=60}"
                                    SemanticProperties.Description="Set intensity to 60 percent, moderate"
                                    AutomationId="Intensity60Button" />

                            <!-- 80% Intensity -->
                            <Button Grid.Row="1" Grid.Column="1"
                                    Text="80%"
                                    Command="{Binding SetIntensityCommand}"
                                    CommandParameter="80"
                                    Style="{StaticResource TertiaryButton}"
                                    BackgroundColor="{Binding Intensity, Converter={StaticResource IntToColorConverter}, ConverterParameter=80}"
                                    SemanticProperties.Description="Set intensity to 80 percent, strong"
                                    AutomationId="Intensity80Button" />

                            <!-- 100% Intensity -->
                            <Button Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                    Text="100%"
                                    Command="{Binding SetIntensityCommand}"
                                    CommandParameter="100"
                                    Style="{StaticResource TertiaryButton}"
                                    BackgroundColor="{Binding Intensity, Converter={StaticResource IntToColorConverter}, ConverterParameter=100}"
                                    SemanticProperties.Description="Set intensity to 100 percent, maximum"
                                    AutomationId="Intensity100Button" />
                        </Grid>

                        <Label Text="{Binding Intensity, StringFormat='Selected: {0}%'}"
                               FontSize="16"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               TextColor="{StaticResource Primary}" />
                    </VerticalStackLayout>

                    <!-- Step 2: Duration Selection (Stepped Buttons) -->
                    <VerticalStackLayout Spacing="12" IsVisible="{Binding CurrentStep, Converter={StaticResource EqualConverter}, ConverterParameter=2}">
                        <Label Text="Select Pulse Duration"
                               Style="{StaticResource Heading3}"
                               HorizontalOptions="Center"
                               SemanticProperties.HeadingLevel="Level3" />

                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="10">
                            <!-- 100ms Duration -->
                            <Button Grid.Row="0" Grid.Column="0"
                                    Text="100ms"
                                    Command="{Binding SetDurationCommand}"
                                    CommandParameter="100"
                                    Style="{StaticResource TertiaryButton}"
                                    BackgroundColor="{Binding Duration, Converter={StaticResource IntToColorConverter}, ConverterParameter=100}"
                                    SemanticProperties.Description="Set duration to 100 milliseconds, very brief"
                                    AutomationId="Duration100Button" />

                            <!-- 500ms Duration -->
                            <Button Grid.Row="0" Grid.Column="1"
                                    Text="500ms"
                                    Command="{Binding SetDurationCommand}"
                                    CommandParameter="500"
                                    Style="{StaticResource TertiaryButton}"
                                    BackgroundColor="{Binding Duration, Converter={StaticResource IntToColorConverter}, ConverterParameter=500}"
                                    SemanticProperties.Description="Set duration to 500 milliseconds, brief"
                                    AutomationId="Duration500Button" />

                            <!-- 1000ms Duration -->
                            <Button Grid.Row="1" Grid.Column="0"
                                    Text="1000ms"
                                    Command="{Binding SetDurationCommand}"
                                    CommandParameter="1000"
                                    Style="{StaticResource TertiaryButton}"
                                    BackgroundColor="{Binding Duration, Converter={StaticResource IntToColorConverter}, ConverterParameter=1000}"
                                    SemanticProperties.Description="Set duration to 1000 milliseconds, 1 second"
                                    AutomationId="Duration1000Button" />

                            <!-- 2000ms Duration -->
                            <Button Grid.Row="1" Grid.Column="1"
                                    Text="2000ms"
                                    Command="{Binding SetDurationCommand}"
                                    CommandParameter="2000"
                                    Style="{StaticResource TertiaryButton}"
                                    BackgroundColor="{Binding Duration, Converter={StaticResource IntToColorConverter}, ConverterParameter=2000}"
                                    SemanticProperties.Description="Set duration to 2000 milliseconds, 2 seconds"
                                    AutomationId="Duration2000Button" />
                        </Grid>

                        <Label Text="{Binding Duration, StringFormat='Selected: {0}ms'}"
                               FontSize="16"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               TextColor="{StaticResource Primary}" />
                    </VerticalStackLayout>

                    <!-- Step 3: Test Fingers -->
                    <VerticalStackLayout Spacing="15" IsVisible="{Binding CurrentStep, Converter={StaticResource EqualConverter}, ConverterParameter=3}">
                        <!-- Selected Finger Display -->
                        <Border Padding="10"
                                BackgroundColor="{StaticResource Primary}"
                                StrokeThickness="0"
                                IsVisible="{Binding IsBuzzing}"
                                SemanticProperties.Description="{Binding SelectedFingerName, StringFormat='Currently testing: {0}'}"
                                AutomationId="TestingFingerBanner">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Label Text="{Binding SelectedFingerName, StringFormat='Testing: {0}'}"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   HorizontalOptions="Center"
                                   AutomationProperties.IsInAccessibleTree="False" />
                        </Border>

                        <!-- Left Hand -->
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Left Hand"
                                   Style="{StaticResource Heading3}"
                                   HorizontalOptions="Center"
                                   SemanticProperties.HeadingLevel="Level3" />

                            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="10">
                                <!-- Left Thumb (Index 0) -->
                                <Button Grid.Row="0" Grid.Column="0"
                                        Text="✓ Thumb"
                                        Command="{Binding BuzzFingerCommand}"
                                        HeightRequest="64"
                                        FontSize="18"
                                        FontAttributes="Bold"
                                        CornerRadius="12"
                                        BackgroundColor="{StaticResource Primary}"
                                        SemanticProperties.Description="Left thumb"
                                        SemanticProperties.Hint="Test left thumb motor"
                                        AutomationId="LeftThumbButton">
                                    <Button.CommandParameter>
                                        <x:Int32>0</x:Int32>
                                    </Button.CommandParameter>
                                </Button>

                                <!-- Left Index (Index 1) -->
                                <Button Grid.Row="0" Grid.Column="1"
                                        Text="✓ Index"
                                        Command="{Binding BuzzFingerCommand}"
                                        HeightRequest="64"
                                        FontSize="18"
                                        FontAttributes="Bold"
                                        CornerRadius="12"
                                        BackgroundColor="{StaticResource Primary}"
                                        SemanticProperties.Description="Left index finger"
                                        SemanticProperties.Hint="Test left index finger motor"
                                        AutomationId="LeftIndexButton">
                                    <Button.CommandParameter>
                                        <x:Int32>1</x:Int32>
                                    </Button.CommandParameter>
                                </Button>

                                <!-- Left Middle (Index 2) -->
                                <Button Grid.Row="1" Grid.Column="0"
                                        Text="✓ Middle"
                                        Command="{Binding BuzzFingerCommand}"
                                        HeightRequest="64"
                                        FontSize="18"
                                        FontAttributes="Bold"
                                        CornerRadius="12"
                                        BackgroundColor="{StaticResource Primary}"
                                        SemanticProperties.Description="Left middle finger"
                                        SemanticProperties.Hint="Test left middle finger motor"
                                        AutomationId="LeftMiddleButton">
                                    <Button.CommandParameter>
                                        <x:Int32>2</x:Int32>
                                    </Button.CommandParameter>
                                </Button>

                                <!-- Left Ring (Index 3) -->
                                <Button Grid.Row="1" Grid.Column="1"
                                        Text="✓ Ring"
                                        Command="{Binding BuzzFingerCommand}"
                                        HeightRequest="64"
                                        FontSize="18"
                                        FontAttributes="Bold"
                                        CornerRadius="12"
                                        BackgroundColor="{StaticResource Primary}"
                                        SemanticProperties.Description="Left ring finger"
                                        SemanticProperties.Hint="Test left ring finger motor"
                                        AutomationId="LeftRingButton">
                                    <Button.CommandParameter>
                                        <x:Int32>3</x:Int32>
                                    </Button.CommandParameter>
                                </Button>
                            </Grid>
                        </VerticalStackLayout>

                        <!-- Right Hand -->
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Right Hand"
                                   Style="{StaticResource Heading3}"
                                   HorizontalOptions="Center"
                                   SemanticProperties.HeadingLevel="Level3" />

                            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="10">
                                <!-- Right Thumb (Index 4) -->
                                <Button Grid.Row="0" Grid.Column="0"
                                        Text="✓ Thumb"
                                        Command="{Binding BuzzFingerCommand}"
                                        HeightRequest="64"
                                        FontSize="18"
                                        FontAttributes="Bold"
                                        CornerRadius="12"
                                        BackgroundColor="{StaticResource Secondary}"
                                        SemanticProperties.Description="Right thumb"
                                        SemanticProperties.Hint="Test right thumb motor"
                                        AutomationId="RightThumbButton">
                                    <Button.CommandParameter>
                                        <x:Int32>4</x:Int32>
                                    </Button.CommandParameter>
                                </Button>

                                <!-- Right Index (Index 5) -->
                                <Button Grid.Row="0" Grid.Column="1"
                                        Text="✓ Index"
                                        Command="{Binding BuzzFingerCommand}"
                                        HeightRequest="64"
                                        FontSize="18"
                                        FontAttributes="Bold"
                                        CornerRadius="12"
                                        BackgroundColor="{StaticResource Secondary}"
                                        SemanticProperties.Description="Right index finger"
                                        SemanticProperties.Hint="Test right index finger motor"
                                        AutomationId="RightIndexButton">
                                    <Button.CommandParameter>
                                        <x:Int32>5</x:Int32>
                                    </Button.CommandParameter>
                                </Button>

                                <!-- Right Middle (Index 6) -->
                                <Button Grid.Row="1" Grid.Column="0"
                                        Text="✓ Middle"
                                        Command="{Binding BuzzFingerCommand}"
                                        HeightRequest="64"
                                        FontSize="18"
                                        FontAttributes="Bold"
                                        CornerRadius="12"
                                        BackgroundColor="{StaticResource Secondary}"
                                        SemanticProperties.Description="Right middle finger"
                                        SemanticProperties.Hint="Test right middle finger motor"
                                        AutomationId="RightMiddleButton">
                                    <Button.CommandParameter>
                                        <x:Int32>6</x:Int32>
                                    </Button.CommandParameter>
                                </Button>

                                <!-- Right Ring (Index 7) -->
                                <Button Grid.Row="1" Grid.Column="1"
                                        Text="✓ Ring"
                                        Command="{Binding BuzzFingerCommand}"
                                        HeightRequest="64"
                                        FontSize="18"
                                        FontAttributes="Bold"
                                        CornerRadius="12"
                                        BackgroundColor="{StaticResource Secondary}"
                                        SemanticProperties.Description="Right ring finger"
                                        SemanticProperties.Hint="Test right ring finger motor"
                                        AutomationId="RightRingButton">
                                    <Button.CommandParameter>
                                        <x:Int32>7</x:Int32>
                                    </Button.CommandParameter>
                                </Button>
                            </Grid>
                        </VerticalStackLayout>
                    </VerticalStackLayout>

                    <!-- Navigation Buttons -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,10,0,0">
                        <Button Grid.Column="0"
                                Text="← Previous"
                                Command="{Binding PreviousStepCommand}"
                                IsEnabled="{Binding CurrentStep, Converter={StaticResource GreaterThanConverter}, ConverterParameter=1}"
                                Style="{StaticResource TertiaryButton}"
                                BackgroundColor="{StaticResource Secondary}"
                                SemanticProperties.Description="Go to previous calibration step"
                                SemanticProperties.Hint="Double tap to go back"
                                AutomationId="PreviousStepButton" />

                        <Button Grid.Column="1"
                                Text="Next →"
                                Command="{Binding NextStepCommand}"
                                IsEnabled="{Binding CurrentStep, Converter={StaticResource LessThanConverter}, ConverterParameter=3}"
                                Style="{StaticResource TertiaryButton}"
                                BackgroundColor="{StaticResource Primary}"
                                SemanticProperties.Description="Go to next calibration step"
                                SemanticProperties.Hint="Double tap to advance"
                                AutomationId="NextStepButton" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Skip Calibration Option (BOTTOM ZONE - Easy reach) -->
            <Button Text="Skip Calibration (Use Defaults)"
                    Command="{Binding SkipCalibrationCommand}"
                    IsVisible="{Binding IsInCalibrationMode}"
                    Style="{StaticResource TertiaryButton}"
                    BackgroundColor="{StaticResource Gray700}"
                    SemanticProperties.Description="Skip calibration and use safe default settings"
                    SemanticProperties.Hint="Bypasses testing and uses 50% intensity, 200ms duration"
                    AutomationId="SkipCalibrationButton" />

            <!-- Info Card -->
            <Border Padding="15"
                    BackgroundColor="{StaticResource CardBackground}"
                    StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>

                <Label Style="{StaticResource SecondaryText}"
                       LineBreakMode="WordWrap"
                       Text="Follow the guided steps to calibrate your gloves: (1) Select intensity, (2) Select duration, (3) Test each finger motor. Or skip to use safe defaults."
                       SemanticProperties.Description="Calibration instructions" />
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
