<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BuzzahBuddy.ViewModels"
             xmlns:models="clr-namespace:BuzzahBuddy.Models"
             xmlns:controls="clr-namespace:BuzzahBuddy.Views.Controls"
             x:Class="BuzzahBuddy.Views.GloveControlPage"
             x:DataType="vm:GloveControlViewModel"
             Title="{Binding Title}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <!-- App Logo/Header -->
            <Image Source="titledark"
                   HeightRequest="60"
                   HorizontalOptions="Center"
                   Margin="0,20,0,0"
                   SemanticProperties.Description="BuzzahBuddy Logo"
                   Aspect="AspectFit" />

            <!-- Page Heading -->
            <Label Text="Therapy Control"
                   Style="{StaticResource Headline}"
                   HorizontalOptions="Center"
                   SemanticProperties.HeadingLevel="Level1" />

            <!-- Reconnection Banner -->
            <Border IsVisible="{Binding ShowReconnectionBanner}"
                    BackgroundColor="{StaticResource Warning}"
                    StrokeThickness="0"
                    Padding="12,8"
                    Margin="0,0,0,8"
                    SemanticProperties.Description="{Binding ConnectionInfo.ReconnectionMessage}"
                    SemanticProperties.Hint="Tap to go to device page"
                    AutomationId="ReconnectionBanner">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding NavigateToDevicesCommand}" />
                </Border.GestureRecognizers>
                <Label Text="{Binding ConnectionInfo.ReconnectionMessage}"
                       TextColor="{StaticResource Black}"
                       FontSize="14"
                       HorizontalTextAlignment="Center"
                       AutomationProperties.IsInAccessibleTree="False" />
            </Border>

            <!-- Disconnected State: Getting Started Guide -->
            <VerticalStackLayout Spacing="20"
                                 IsVisible="{Binding ConnectionInfo.IsConnected, Converter={StaticResource InvertedBoolConverter}}">

                <Border Padding="24"
                        BackgroundColor="{StaticResource CardBackground}"
                        StrokeThickness="1"
                        Stroke="{StaticResource CardBorder}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="{StaticResource GlowBrush}"
                                Offset="0,0"
                                Radius="15"
                                Opacity="0.15" />
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="20">
                        <Label Text="Getting Started"
                               FontSize="20"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               SemanticProperties.HeadingLevel="Level2" />

                        <!-- Step 1 -->
                        <HorizontalStackLayout Spacing="16">
                            <Border WidthRequest="40"
                                    HeightRequest="40"
                                    BackgroundColor="{StaticResource Primary}"
                                    StrokeThickness="0"
                                    AutomationProperties.IsInAccessibleTree="False">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="20" />
                                </Border.StrokeShape>
                                <Label Text="1"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource Black}"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                                <Label Text="Power on your gloves"
                                       FontSize="16"
                                       FontAttributes="Bold" />
                                <Label Text="Press the button on each glove"
                                       FontSize="14"
                                       TextColor="{StaticResource TextMuted}" />
                            </VerticalStackLayout>
                        </HorizontalStackLayout>

                        <!-- Step 2 -->
                        <HorizontalStackLayout Spacing="16">
                            <Border WidthRequest="40"
                                    HeightRequest="40"
                                    BackgroundColor="{StaticResource Primary}"
                                    StrokeThickness="0"
                                    AutomationProperties.IsInAccessibleTree="False">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="20" />
                                </Border.StrokeShape>
                                <Label Text="2"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource Black}"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                                <Label Text="Connect via Bluetooth"
                                       FontSize="16"
                                       FontAttributes="Bold" />
                                <Label Text="Tap below to find your gloves"
                                       FontSize="14"
                                       TextColor="{StaticResource TextMuted}" />
                            </VerticalStackLayout>
                        </HorizontalStackLayout>

                        <!-- Step 3 -->
                        <HorizontalStackLayout Spacing="16">
                            <Border WidthRequest="40"
                                    HeightRequest="40"
                                    BackgroundColor="{StaticResource Primary}"
                                    StrokeThickness="0"
                                    AutomationProperties.IsInAccessibleTree="False">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="20" />
                                </Border.StrokeShape>
                                <Label Text="3"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource Black}"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                                <Label Text="Start your therapy session"
                                       FontSize="16"
                                       FontAttributes="Bold" />
                                <Label Text="Come back here and press Start"
                                       FontSize="14"
                                       TextColor="{StaticResource TextMuted}" />
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <Button Text="Find Devices"
                        Command="{Binding NavigateToDevicesCommand}"
                        Style="{StaticResource PrimaryButtonGlow}"
                        SemanticProperties.Description="Go to the device page to scan for gloves"
                        SemanticProperties.Hint="Double tap to activate"
                        AutomationId="FindDevicesButton" />
            </VerticalStackLayout>

            <!-- Connected State -->
            <VerticalStackLayout Spacing="20"
                                 IsVisible="{Binding ConnectionInfo.IsConnected}">

                <!-- Session Status Card (visible during active/paused session) -->
                <Border Style="{StaticResource CardWithGlow}"
                        Padding="20"
                        IsVisible="{Binding IsSessionActive}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16" />
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="16">
                        <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                            <Label Text="Status:"
                                   FontSize="14"
                                   VerticalOptions="Center" />
                            <Label Text="{Binding SessionStatus.Status}"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>

                        <controls:SessionTimerView Progress="{Binding TimerProgressFraction}"
                                                   TimeText="{Binding TimerRemainingText}"
                                                   Caption="{Binding TimerCaption}"
                                                   IsPaused="{Binding IsSessionPaused}"
                                                   HeightRequest="270"
                                                   SemanticProperties.Description="{Binding TimerSemanticDescription}"
                                                   AutomationId="SessionTimerRing" />

                        <Label Text="{Binding TimerElapsedText}"
                               FontSize="14"
                               TextColor="{StaticResource TextMuted}"
                               HorizontalTextAlignment="Center"
                               IsVisible="{Binding TimerElapsedText, Converter={StaticResource IsNotNullConverter}}"
                               AutomationProperties.IsInAccessibleTree="False" />
                    </VerticalStackLayout>
                </Border>

                <Label Text="{Binding SessionWarningMessage}"
                       IsVisible="{Binding SessionWarningMessage, Converter={StaticResource IsNotNullConverter}}"
                       TextColor="{StaticResource Warning}"
                       FontSize="14"
                       HorizontalTextAlignment="Center"
                       SemanticProperties.Description="{Binding SessionWarningMessage}"
                       AutomationId="SessionWarningLabel" />

                <!-- Current Profile Card (read-only, tap to change on Device page) -->
                <Border Padding="20"
                        BackgroundColor="{StaticResource CardBackground}"
                        StrokeThickness="1"
                        Stroke="{StaticResource CardBorder}"
                        SemanticProperties.Description="{Binding SelectedProfileName, StringFormat='Current therapy profile: {0}'}"
                        SemanticProperties.Hint="Double tap to change the profile on the device page"
                        AutomationId="CurrentProfileCard">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12" />
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NavigateToDevicesCommand}" />
                    </Border.GestureRecognizers>

                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="4">
                        <Label Grid.Row="0" Grid.Column="0"
                               Text="Therapy Profile"
                               FontSize="14"
                               TextColor="{StaticResource TextMuted}"
                               AutomationProperties.IsInAccessibleTree="False" />
                        <Label Grid.Row="1" Grid.Column="0"
                               Text="{Binding SelectedProfileName}"
                               FontSize="20"
                               FontAttributes="Bold"
                               AutomationProperties.IsInAccessibleTree="False" />
                        <Label Grid.Row="2" Grid.Column="0"
                               Text="{Binding ProfileSummary}"
                               FontSize="14"
                               TextColor="{StaticResource TextMuted}"
                               AutomationProperties.IsInAccessibleTree="False" />
                        <Label Grid.Row="0" Grid.RowSpan="3" Grid.Column="1"
                               Text="Change ›"
                               FontSize="16"
                               TextColor="{StaticResource Primary}"
                               VerticalOptions="Center"
                               AutomationProperties.IsInAccessibleTree="False" />
                    </Grid>
                </Border>

                <!-- Battery: one row per glove (dot | name | value), columns aligned -->
                <Grid ColumnDefinitions="Auto,Auto,*"
                      RowDefinitions="Auto,Auto"
                      ColumnSpacing="8"
                      RowSpacing="10">
                    <Label Grid.Row="0" Grid.Column="0"
                           Text="●"
                           FontSize="16"
                           TextColor="{Binding BatteryPrimaryColor}"
                           VerticalOptions="Center"
                           AutomationProperties.IsInAccessibleTree="False" />
                    <Label Grid.Row="0" Grid.Column="1"
                           Text="Primary:"
                           FontSize="14"
                           VerticalOptions="Center"
                           AutomationProperties.IsInAccessibleTree="False" />
                    <Label Grid.Row="0" Grid.Column="2"
                           Text="{Binding BatteryPrimaryText}"
                           FontSize="16"
                           FontAttributes="Bold"
                           HorizontalOptions="End"
                           VerticalOptions="Center"
                           SemanticProperties.Description="{Binding BatteryPrimaryDescription}" />

                    <Label Grid.Row="1" Grid.Column="0"
                           Text="●"
                           FontSize="16"
                           TextColor="{Binding BatterySecondaryColor}"
                           VerticalOptions="Center"
                           AutomationProperties.IsInAccessibleTree="False" />
                    <Label Grid.Row="1" Grid.Column="1"
                           Text="Secondary:"
                           FontSize="14"
                           VerticalOptions="Center"
                           AutomationProperties.IsInAccessibleTree="False" />
                    <Label Grid.Row="1" Grid.Column="2"
                           Text="{Binding BatterySecondaryText}"
                           FontSize="16"
                           FontAttributes="Bold"
                           HorizontalOptions="End"
                           VerticalOptions="Center"
                           SemanticProperties.Description="{Binding BatterySecondaryDescription}" />
                </Grid>

                <!-- Primary Session Control Button (Start/Pause/Resume) -->
                <Button Text="{Binding SessionButtonText}"
                        Command="{Binding ToggleSessionCommand}"
                        Style="{StaticResource PrimaryButtonGlow}"
                        SemanticProperties.Hint="Double tap to activate"
                        SemanticProperties.Description="{Binding SessionButtonDescription}"
                        AutomationId="SessionControlButton">
                    <Button.IsEnabled>
                        <MultiBinding Converter="{StaticResource AllTrueConverter}">
                            <Binding Path="IsNotBusy" />
                            <Binding Path="ConnectionInfo.IsConnected" />
                        </MultiBinding>
                    </Button.IsEnabled>
                </Button>

                <!-- Stop Session Button (only visible when session is active) -->
                <Button Text="Stop Session"
                        Command="{Binding StopSessionCommand}"
                        Style="{StaticResource DangerActionButton}"
                        IsVisible="{Binding IsSessionActive}"
                        SemanticProperties.Hint="Double tap to stop the current session"
                        SemanticProperties.Description="Stops the active therapy session"
                        AutomationId="StopSessionButton">
                    <Button.IsEnabled>
                        <MultiBinding Converter="{StaticResource AllTrueConverter}">
                            <Binding Path="IsNotBusy" />
                            <Binding Path="ConnectionInfo.IsConnected" />
                        </MultiBinding>
                    </Button.IsEnabled>
                </Button>

            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
