<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BuzzahBuddy.ViewModels"
             xmlns:models="clr-namespace:BuzzahBuddy.Models"
             x:Class="BuzzahBuddy.Views.GloveControlPage"
             x:DataType="vm:GloveControlViewModel"
             Title="{Binding Title}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="25">

            <!-- Header -->
            <Label Text="Device Control"
                   Style="{StaticResource Headline}"
                   SemanticProperties.HeadingLevel="Level1"
                   HorizontalOptions="Center" />

            <!-- Battery Status -->
            <Border Padding="15"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}"
                    StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="10">
                    <Label Text="Battery Status"
                           FontSize="16"
                           FontAttributes="Bold"
                           HorizontalOptions="Center" />

                    <HorizontalStackLayout Spacing="20" HorizontalOptions="Center">
                        <!-- Left Device Battery -->
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Left Device"
                                   FontSize="12"
                                   HorizontalOptions="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
                            <Label Text="{Binding BatteryLeftVoltage, StringFormat='{0:F2}V'}"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"
                                   TextColor="{Binding BatteryLeftColor}"
                                   SemanticProperties.Description="Left device battery voltage" />
                        </VerticalStackLayout>

                        <!-- Right Device Battery -->
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Right Device"
                                   FontSize="12"
                                   HorizontalOptions="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
                            <Label Text="{Binding BatteryRightVoltage, StringFormat='{0:F2}V'}"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"
                                   TextColor="{Binding BatteryRightColor}"
                                   SemanticProperties.Description="Right device battery voltage" />
                        </VerticalStackLayout>
                    </HorizontalStackLayout>

                    <Button Text="🔄 Refresh Battery"
                            Command="{Binding RefreshBatteryCommand}"
                            HeightRequest="40"
                            FontSize="14"
                            CornerRadius="8"
                            HorizontalOptions="Center"
                            Padding="20,0"
                            SemanticProperties.Hint="Refresh battery levels"
                            AutomationId="RefreshBatteryButton" />
                </VerticalStackLayout>
            </Border>

            <!-- Profile Selection -->
            <VerticalStackLayout Spacing="10">
                <Label Text="Therapy Profile"
                       FontSize="18"
                       FontAttributes="Bold"
                       SemanticProperties.HeadingLevel="Level2" />

                <Picker ItemsSource="{Binding AvailableProfiles}"
                        SelectedItem="{Binding SelectedProfile}"
                        ItemDisplayBinding="{Binding Name}"
                        FontSize="16"
                        HeightRequest="48"
                        SemanticProperties.Description="Select therapy profile"
                        AutomationId="ProfilePicker" />

                <Label Text="{Binding SelectedProfile.Description}"
                       FontSize="14"
                       TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"
                       LineBreakMode="WordWrap" />
            </VerticalStackLayout>

            <!-- Profile Details -->
            <Border Padding="15"
                    BackgroundColor="{AppThemeBinding Light={StaticResource SecondaryLight}, Dark={StaticResource Gray900}}"
                    StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>

                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnSpacing="15" RowSpacing="10">
                    <Label Grid.Row="0" Grid.Column="0"
                           Text="Time On:"
                           FontSize="14" />
                    <Label Grid.Row="0" Grid.Column="1"
                           Text="{Binding SelectedProfile.TimeOn, StringFormat='{0:F3}s'}"
                           FontSize="14"
                           FontAttributes="Bold"
                           HorizontalOptions="End" />

                    <Label Grid.Row="1" Grid.Column="0"
                           Text="Time Off:"
                           FontSize="14" />
                    <Label Grid.Row="1" Grid.Column="1"
                           Text="{Binding SelectedProfile.TimeOff, StringFormat='{0:F3}s'}"
                           FontSize="14"
                           FontAttributes="Bold"
                           HorizontalOptions="End" />

                    <Label Grid.Row="2" Grid.Column="0"
                           Text="Frequency:"
                           FontSize="14" />
                    <Label Grid.Row="2" Grid.Column="1"
                           Text="{Binding SelectedProfile.ActuatorFrequency, StringFormat='{0} Hz'}"
                           FontSize="14"
                           FontAttributes="Bold"
                           HorizontalOptions="End" />

                    <Label Grid.Row="3" Grid.Column="0"
                           Text="Amplitude:"
                           FontSize="14" />
                    <Label Grid.Row="3" Grid.Column="1"
                           Text="{Binding SelectedProfile.AmplitudeMin, StringFormat='{0}%-'}"
                           FontSize="14"
                           FontAttributes="Bold"
                           HorizontalOptions="End" />

                    <Label Grid.Row="4" Grid.Column="0"
                           Text="Session Duration:"
                           FontSize="14" />
                    <Label Grid.Row="4" Grid.Column="1"
                           Text="{Binding SelectedProfile.TimeSession, StringFormat='{0} min'}"
                           FontSize="14"
                           FontAttributes="Bold"
                           HorizontalOptions="End" />
                </Grid>
            </Border>

            <!-- Session Status Display -->
            <Border Padding="15"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}"
                    StrokeThickness="0"
                    IsVisible="{Binding IsSessionActive}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="10">
                    <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                        <Label Text="Status:"
                               FontSize="14"
                               VerticalOptions="Center" />
                        <Label Text="{Binding SessionStatus.Status}"
                               FontSize="14"
                               FontAttributes="Bold"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <ProgressBar Progress="{Binding SessionStatus.Progress}"
                                 HeightRequest="8"
                                 ProgressColor="{StaticResource Primary}" />

                    <HorizontalStackLayout Spacing="20" HorizontalOptions="Center">
                        <Label Text="{Binding SessionStatus.ElapsedTimeFormatted, StringFormat='Elapsed: {0}'}"
                               FontSize="14" />
                        <Label Text="{Binding SessionStatus.RemainingTimeFormatted, StringFormat='Remaining: {0}'}"
                               FontSize="14" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Session Control Buttons -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <!-- Start/Stop Button -->
                <Button Grid.Column="0"
                        Text="{Binding SessionButtonText}"
                        Command="{Binding ToggleSessionCommand}"
                        HeightRequest="72"
                        FontSize="20"
                        FontAttributes="Bold"
                        CornerRadius="16"
                        IsEnabled="{Binding IsNotBusy}"
                        BackgroundColor="{StaticResource Primary}"
                        SemanticProperties.Hint="Start or stop therapy session"
                        SemanticProperties.Description="Main session control button"
                        AutomationId="ToggleSessionButton" />

                <!-- Pause/Resume Button -->
                <Button Grid.Column="1"
                        Text="{Binding PauseButtonText}"
                        Command="{Binding PauseResumeSessionCommand}"
                        HeightRequest="72"
                        FontSize="20"
                        FontAttributes="Bold"
                        CornerRadius="16"
                        IsEnabled="{Binding IsSessionActive}"
                        BackgroundColor="{StaticResource Secondary}"
                        SemanticProperties.Hint="Pause or resume therapy session"
                        SemanticProperties.Description="Pause/Resume control button"
                        AutomationId="PauseResumeButton" />
            </Grid>

            <!-- Test Button -->
            <Button Text="Test Connection"
                    Command="{Binding TestConnectionCommand}"
                    HeightRequest="56"
                    FontSize="16"
                    CornerRadius="12"
                    IsEnabled="{Binding IsNotBusy}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource PrimaryDark}}"
                    SemanticProperties.Hint="Send a brief test pulse to the device"
                    SemanticProperties.Description="Test connection with brief vibration pulse"
                    AutomationId="TestConnectionButton" />

            <!-- Info Card -->
            <Border Padding="15"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}"
                    Margin="0,20,0,0"
                    StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>

                <Label FontSize="14"
                       LineBreakMode="WordWrap"
                       Text="Select a therapy profile and press 'Start Session' to begin. You can pause/resume during the session. Your session will be automatically tracked."
                       SemanticProperties.Description="Usage instructions" />
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
