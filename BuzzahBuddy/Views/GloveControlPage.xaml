<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BuzzahBuddy.ViewModels"
             xmlns:models="clr-namespace:BuzzahBuddy.Models"
             xmlns:viewmodels="clr-namespace:BuzzahBuddy.ViewModels"
             x:Class="BuzzahBuddy.Views.GloveControlPage"
             x:DataType="vm:GloveControlViewModel"
             x:Name="page"
             Title="{Binding Title}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <!-- TOP ZONE (Difficult): Status & Info (Read-Only) -->

            <!-- Reconnection Banner -->
            <Border IsVisible="{Binding ShowReconnectionBanner}"
                    BackgroundColor="{StaticResource Warning}"
                    StrokeThickness="0"
                    Padding="12,8"
                    Margin="0,0,0,8"
                    SemanticProperties.Description="{Binding ReconnectionMessage}"
                    SemanticProperties.Hint="Tap to go to devices page"
                    AutomationId="ReconnectionBanner">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding NavigateToDevicesCommand}" />
                </Border.GestureRecognizers>
                <Label Text="{Binding ReconnectionMessage}"
                       TextColor="{StaticResource Black}"
                       FontSize="14"
                       HorizontalTextAlignment="Center"
                       AutomationProperties.IsInAccessibleTree="False" />
            </Border>

            <!-- Header -->
            <Label Text="Device Control"
                   Style="{StaticResource Headline}"
                   SemanticProperties.HeadingLevel="Level1"
                   HorizontalOptions="Center" />

            <!-- Session Status Display (Top Zone - Info only) -->
            <Border Padding="15"
                    BackgroundColor="{StaticResource CardBackground}"
                    StrokeThickness="0"
                    IsVisible="{Binding IsSessionActive}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="10">
                    <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                        <Label Text="Status:"
                               FontSize="14"
                               VerticalOptions="Center" />
                        <Label Text="{Binding SessionStatus.Status}"
                               FontSize="14"
                               FontAttributes="Bold"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <ProgressBar Progress="{Binding SessionStatus.Progress}"
                                 HeightRequest="8"
                                 ProgressColor="{StaticResource Primary}"
                                 SemanticProperties.Description="Session progress"
                                 AutomationId="SessionProgressBar" />

                    <HorizontalStackLayout Spacing="20" HorizontalOptions="Center">
                        <Label Text="{Binding SessionStatus.ElapsedTimeFormatted, StringFormat='Elapsed: {0}'}"
                               FontSize="14" />
                        <Label Text="{Binding SessionStatus.RemainingTimeFormatted, StringFormat='Remaining: {0}'}"
                               FontSize="14" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Label Text="{Binding SessionWarningMessage}"
                   IsVisible="{Binding SessionWarningMessage, Converter={StaticResource IsNotNullConverter}}"
                   TextColor="{StaticResource Warning}"
                   FontSize="14"
                   HorizontalTextAlignment="Center"
                   SemanticProperties.Description="{Binding SessionWarningMessage}"
                   AutomationId="SessionWarningLabel" />

            <!-- Battery Status (Streamlined) -->
            <Border Padding="15"
                    BackgroundColor="{StaticResource CardBackground}"
                    StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="12">
                    <Label Text="Battery Status"
                           FontSize="16"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           SemanticProperties.HeadingLevel="Level2" />

                    <HorizontalStackLayout Spacing="15" HorizontalOptions="Center">
                        <!-- Primary Glove -->
                        <HorizontalStackLayout Spacing="8"
                                               SemanticProperties.Description="{Binding BatteryPrimaryPercentage, StringFormat='Primary battery: {0} percent'}">
                            <Label Text="●"
                                   FontSize="16"
                                   TextColor="{Binding BatteryPrimaryColor}"
                                   VerticalOptions="Center"
                                   AutomationProperties.IsInAccessibleTree="False" />
                            <Label VerticalOptions="Center"
                                   AutomationProperties.IsInAccessibleTree="False">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="Primary: " FontSize="14" />
                                        <Span Text="{Binding BatteryPrimaryPercentage, StringFormat='{0}%'}"
                                              FontSize="16"
                                              FontAttributes="Bold" />
                                        <Span Text="{Binding BatteryPrimaryVoltage, StringFormat=' ({0:F2}V)'}"
                                              FontSize="12"
                                              TextColor="{StaticResource TextMuted}" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                        </HorizontalStackLayout>

                        <!-- Secondary Glove -->
                        <HorizontalStackLayout Spacing="8"
                                               SemanticProperties.Description="{Binding BatterySecondaryPercentage, StringFormat='Secondary battery: {0} percent'}">
                            <Label Text="●"
                                   FontSize="16"
                                   TextColor="{Binding BatterySecondaryColor}"
                                   VerticalOptions="Center"
                                   AutomationProperties.IsInAccessibleTree="False" />
                            <Label VerticalOptions="Center"
                                   AutomationProperties.IsInAccessibleTree="False">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="Secondary: " FontSize="14" />
                                        <Span Text="{Binding BatterySecondaryPercentage, StringFormat='{0}%'}"
                                              FontSize="16"
                                              FontAttributes="Bold" />
                                        <Span Text="{Binding BatterySecondaryVoltage, StringFormat=' ({0:F2}V)'}"
                                              FontSize="12"
                                              TextColor="{StaticResource TextMuted}" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                        </HorizontalStackLayout>
                    </HorizontalStackLayout>

                    <VerticalStackLayout Spacing="8" IsVisible="{Binding ShowBatteryRefresh}" HorizontalOptions="Center">
                        <ActivityIndicator IsRunning="{Binding IsRefreshingBattery}"
                                           IsVisible="{Binding IsRefreshingBattery}"
                                           HeightRequest="20"
                                           WidthRequest="20"
                                           SemanticProperties.Description="Refreshing battery status" />
                        <Button Text="🔄 Refresh"
                                Command="{Binding RefreshBatteryCommand}"
                                HeightRequest="48"
                                FontSize="14"
                                CornerRadius="8"
                                HorizontalOptions="Center"
                                Padding="20,0"
                                IsEnabled="{Binding IsRefreshingBattery, Converter={StaticResource InvertedBoolConverter}}"
                                SemanticProperties.Hint="Refresh battery levels"
                                SemanticProperties.Description="Updates the current battery status"
                                AutomationId="RefreshBatteryButton" />
                    </VerticalStackLayout>

                    <Label Text="{Binding BatteryStatusMessage}"
                           IsVisible="{Binding BatteryStatusMessage, Converter={StaticResource IsNotNullConverter}}"
                           TextColor="{StaticResource Warning}"
                           FontSize="12"
                           HorizontalTextAlignment="Center"
                           SemanticProperties.Description="Battery status warning" />
                </VerticalStackLayout>
            </Border>

            <!-- Profile Selection (Card-Based) -->
            <VerticalStackLayout Spacing="12">
                <HorizontalStackLayout Spacing="10">
                    <Label Text="Therapy Profile"
                           Style="{StaticResource Heading2}"
                           VerticalOptions="Center"
                           SemanticProperties.HeadingLevel="Level2" />
                    <ActivityIndicator IsRunning="{Binding IsLoadingProfile}"
                                       IsVisible="{Binding IsLoadingProfile}"
                                       HeightRequest="20"
                                       WidthRequest="20"
                                       VerticalOptions="Center"
                                       SemanticProperties.Description="Loading profile" />
                </HorizontalStackLayout>

                <Label Text="{Binding ProfileLoadingMessage}"
                       IsVisible="{Binding ProfileLoadingMessage, Converter={StaticResource IsNotNullConverter}}"
                       TextColor="{StaticResource Warning}"
                       FontSize="12"
                       SemanticProperties.Description="Profile loading fallback notification" />

                <!-- Profile Cards - NO CollectionView selection styling -->
                <VerticalStackLayout BindableLayout.ItemsSource="{Binding AvailableProfiles}"
                                     Spacing="16">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="vm:ProfileItemViewModel">
                            <Border Padding="20"
                                    BackgroundColor="{StaticResource CardBackground}"
                                    StrokeThickness="2"
                                    Stroke="{StaticResource CardBorder}"
                                    SemanticProperties.Description="{Binding DisplayName}"
                                    SemanticProperties.Hint="Tap to select this therapy profile">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12" />
                                </Border.StrokeShape>

                                <!-- Tap to select this profile -->
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={x:Reference page}, Path=BindingContext.SelectProfileCommand}"
                                                          CommandParameter="{Binding}" />
                                </Border.GestureRecognizers>

                                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" ColumnSpacing="16" RowSpacing="8">
                                    <!-- Blue circle checkmark - SIMPLE binding to IsSelected -->
                                    <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
                                            WidthRequest="56"
                                            HeightRequest="56"
                                            BackgroundColor="{StaticResource Primary}"
                                            VerticalOptions="Center"
                                            HorizontalOptions="Center"
                                            IsVisible="{Binding IsSelected}"
                                            AutomationProperties.IsInAccessibleTree="False">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="28" />
                                        </Border.StrokeShape>

                                        <Label Text="✓"
                                               FontSize="32"
                                               FontAttributes="Bold"
                                               TextColor="White"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center" />
                                    </Border>

                                    <!-- Profile Name -->
                                    <Label Grid.Row="0" Grid.Column="1"
                                           Text="{Binding Name}"
                                           FontSize="20"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource TextPrimary}"
                                           AutomationProperties.IsInAccessibleTree="False" />

                                    <!-- Profile Description -->
                                    <Label Grid.Row="1" Grid.Column="1"
                                           Text="{Binding Description}"
                                           FontSize="15"
                                           TextColor="{StaticResource TextMuted}"
                                           LineBreakMode="WordWrap"
                                           AutomationProperties.IsInAccessibleTree="False" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>

                <!-- Empty State: No Profile Selected -->
                <Border Padding="16"
                        Margin="0,8,0,0"
                        BackgroundColor="{StaticResource CardBackground}"
                        StrokeThickness="0"
                        IsVisible="{Binding SelectedProfile, Converter={StaticResource InvertedBoolConverter}}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <HorizontalStackLayout Spacing="12">
                        <Label Text="ℹ️"
                               FontSize="24"
                               VerticalOptions="Center"
                               AutomationProperties.IsInAccessibleTree="False" />
                        <Label Text="Please select a therapy profile above to begin."
                               Style="{StaticResource BodyText}"
                               LineBreakMode="WordWrap"
                               VerticalOptions="Center"
                               SemanticProperties.Description="Please select a therapy profile above to begin" />
                    </HorizontalStackLayout>
                </Border>
            </VerticalStackLayout>

            <!-- Profile Details (Top Zone - Info only, collapsed during session) -->
            <Border Padding="20"
                    BackgroundColor="{StaticResource Gray950}"
                    StrokeThickness="1"
                    Stroke="{StaticResource CardBorder}"
                    IsVisible="{Binding IsSessionActive, Converter={StaticResource InvertedBoolConverter}}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="12">
                    <!-- Section Heading -->
                    <Label Text="Profile Settings"
                           FontSize="16"
                           FontAttributes="Bold"
                           Margin="0,0,0,8"
                           SemanticProperties.HeadingLevel="Level3" />

                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnSpacing="20" RowSpacing="12">
                        <Label Grid.Row="0" Grid.Column="0"
                               Text="Time On:"
                               FontSize="16" />
                        <Label Grid.Row="0" Grid.Column="1"
                               Text="{Binding SelectedProfile.TimeOn, StringFormat='{0:F3}s'}"
                               FontSize="16"
                               FontAttributes="Bold"
                               HorizontalOptions="End" />

                        <Label Grid.Row="1" Grid.Column="0"
                               Text="Time Off:"
                               FontSize="16" />
                        <Label Grid.Row="1" Grid.Column="1"
                               Text="{Binding SelectedProfile.TimeOff, StringFormat='{0:F3}s'}"
                               FontSize="16"
                               FontAttributes="Bold"
                               HorizontalOptions="End" />

                        <Label Grid.Row="2" Grid.Column="0"
                               Text="Frequency:"
                               FontSize="16" />
                        <Label Grid.Row="2" Grid.Column="1"
                               Text="{Binding SelectedProfile.ActuatorFrequency, StringFormat='{0} Hz'}"
                               FontSize="16"
                               FontAttributes="Bold"
                               HorizontalOptions="End" />

                        <Label Grid.Row="3" Grid.Column="0"
                               Text="Amplitude:"
                               FontSize="16" />
                        <Label Grid.Row="3" Grid.Column="1"
                               Text="{Binding SelectedProfile.AmplitudeMin, StringFormat='{0}%'}"
                               FontSize="16"
                               FontAttributes="Bold"
                               HorizontalOptions="End" />

                        <Label Grid.Row="4" Grid.Column="0"
                               Text="Session Duration:"
                               FontSize="16" />
                        <Label Grid.Row="4" Grid.Column="1"
                               Text="{Binding SelectedProfile.TimeSession, StringFormat='{0} min'}"
                               FontSize="16"
                               FontAttributes="Bold"
                               HorizontalOptions="End" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- MIDDLE ZONE (Comfortable): Secondary Controls -->

            <!-- Test Connection Button (Middle - only when NOT in session) -->
            <VerticalStackLayout Spacing="8" IsVisible="{Binding IsSessionActive, Converter={StaticResource InvertedBoolConverter}}" HorizontalOptions="Center">
                <ActivityIndicator IsRunning="{Binding IsTestingConnection}"
                                   IsVisible="{Binding IsTestingConnection}"
                                   HeightRequest="20"
                                   WidthRequest="20"
                                   SemanticProperties.Description="Testing connection" />
                <Button Text="Test Connection"
                        Command="{Binding TestConnectionCommand}"
                        HeightRequest="48"
                        FontSize="16"
                        CornerRadius="12"
                        IsEnabled="{Binding IsTestingConnection, Converter={StaticResource InvertedBoolConverter}}"
                        BackgroundColor="{StaticResource Primary}"
                        SemanticProperties.Hint="Send a brief test pulse to the device"
                        SemanticProperties.Description="Test connection with brief vibration pulse"
                        AutomationId="TestConnectionButton" />
            </VerticalStackLayout>

            <!-- Spacer to push primary actions to bottom -->
            <BoxView HeightRequest="20" Color="Transparent" IsVisible="False" />

            <!-- BOTTOM ZONE (Easy): Primary Actions -->

            <!-- Session Control Buttons -->
            <VerticalStackLayout Spacing="12">
                <!-- Primary Session Control Button (Start/Pause/Resume) -->
                <Button Text="{Binding SessionButtonText}"
                        Command="{Binding ToggleSessionCommand}"
                        HeightRequest="72"
                        FontSize="20"
                        FontAttributes="Bold"
                        CornerRadius="16"
                        IsEnabled="{Binding IsNotBusy}"
                        BackgroundColor="{StaticResource Primary}"
                        SemanticProperties.Hint="Double tap to activate"
                        SemanticProperties.Description="{Binding SessionButtonDescription}"
                        AutomationId="SessionControlButton" />

                <!-- Stop Session Button (only visible when session is active) -->
                <Button Text="Stop Session"
                        Command="{Binding StopSessionCommand}"
                        HeightRequest="56"
                        FontSize="18"
                        FontAttributes="Bold"
                        CornerRadius="12"
                        IsEnabled="{Binding IsNotBusy}"
                        IsVisible="{Binding IsSessionActive}"
                        BackgroundColor="{StaticResource PastelDanger}"
                        SemanticProperties.Hint="Double tap to stop the current session"
                        SemanticProperties.Description="Stops the active therapy session"
                        AutomationId="StopSessionButton" />
            </VerticalStackLayout>

            <!-- Info Card (only show when NO profile selected AND not in session) -->
            <Border Padding="12"
                    BackgroundColor="{StaticResource CardBackground}"
                    Margin="0,12,0,0"
                    StrokeThickness="0">
                <Border.IsVisible>
                    <MultiBinding Converter="{StaticResource AllTrueConverter}">
                        <Binding Path="IsSessionActive" Converter="{StaticResource InvertedBoolConverter}" />
                        <Binding Path="SelectedProfile" Converter="{StaticResource InvertedBoolConverter}" />
                    </MultiBinding>
                </Border.IsVisible>
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>

                <HorizontalStackLayout Spacing="10">
                    <Label Text="ℹ️"
                           FontSize="20"
                           VerticalOptions="Center"
                           AutomationProperties.IsInAccessibleTree="False" />
                    <Label FontSize="14"
                           LineBreakMode="WordWrap"
                           Text="Select a therapy profile above to begin."
                           TextColor="{StaticResource TextMuted}"
                           VerticalOptions="Center"
                           SemanticProperties.Description="Select a therapy profile above to begin" />
                </HorizontalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
